{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["vitest/globals"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js"
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
